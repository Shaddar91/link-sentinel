# Link Sentinel Configuration
# Copy this file to .env and fill in the values

# Required: Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required: Your Telegram user ID (get it from @userinfobot)
# Bot always responds to you in DMs
TELEGRAM_OWNER_ID=123456789

# Optional: JSON array of group chat IDs where the bot responds
# Add bot to each group, run /chatid in-group (as owner) to get the ID
# Anyone outside your DMs + these groups is ignored
# TELEGRAM_GROUP_IDS=[-1001234567890,-1009876543210]

# Optional: Where GitHub repos are cloned for analysis
# GITHUB_CLONE_DIR=/home/shaddar/Documents/workspace/personal/projects/github/repo-analysis/cloned

# Optional: Where repo analysis documents are saved
# GITHUB_ANALYSIS_DIR=/home/shaddar/Documents/workspace/personal/projects/github/repo-analysis/analysis-docs

# Optional: Where YouTube transcripts are saved (same dir as `trans` command)
# YOUTUBE_TRANSCRIPT_DIR=/home/shaddar/.transcribes

# Optional: Pipeline task queue directory
# PIPELINE_TRANSPOSED_DIR=/home/shaddar/Documents/workspace/ai-task-automation/data/pipeline/transposed

# Optional: Auto-analyze when links are detected (true/false)
AUTO_ANALYZE=true

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
